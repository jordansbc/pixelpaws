<Window x:Class="DesktopPet.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixelPaws Settings"
        Width="340" Height="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <StackPanel Margin="20">
        <TextBlock Text="🐾 PixelPaws" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

        <TextBlock Text="Speed" Margin="0,0,0,2"/>
        <Slider x:Name="SpeedSlider" Minimum="0.3" Maximum="2.5" TickFrequency="0.1"
                IsSnapToTickEnabled="True" Margin="0,0,0,10"/>

        <TextBlock Text="Size" Margin="0,0,0,2"/>
        <ComboBox x:Name="SizeBox" Width="140" HorizontalAlignment="Left" Margin="0,0,0,14">
            <ComboBoxItem Content="Small"  Tag="0.75"/>
            <ComboBoxItem Content="Medium" Tag="1.0"/>
            <ComboBoxItem Content="Large"  Tag="1.3"/>
            <ComboBoxItem Content="Huge"   Tag="1.6"/>
        </ComboBox>

        <TextBlock Text="Cat color" Margin="0,0,0,2"/>
        <ComboBox x:Name="CatColorBox" Width="140" HorizontalAlignment="Left" Margin="0,0,0,2">
            <ComboBoxItem Content="Gray"         Tag="cat"/>
            <ComboBoxItem Content="Orange"       Tag="cat-orange"/>
            <ComboBoxItem Content="Silver tabby" Tag="cat-silver"/>
            <ComboBoxItem Content="Cream"        Tag="cat-cream"/>
            <ComboBoxItem Content="Chocolate"    Tag="cat-chocolate"/>
            <ComboBoxItem Content="Blue"         Tag="cat-blue"/>
            <ComboBoxItem Content="Janet"        Tag="cat-janet"/>
        </ComboBox>
        <TextBlock x:Name="ColorRestartNote" Text="Restart PixelPaws to apply the new color 🐱"
                   FontSize="10" Foreground="#FF8855BB" Margin="0,0,0,14"
                   Visibility="Collapsed"/>

        <CheckBox x:Name="WindowWalkingBox" Content="Walk on top of windows"    Margin="0,4"/>
        <CheckBox x:Name="CursorChaseBox"   Content="Chase the mouse cursor"    Margin="0,4"/>
        <CheckBox x:Name="SleepBox"         Content="Take naps"                 Margin="0,4"/>
        <CheckBox x:Name="ScrollPlayBox"    Content="Unroll toilet paper when I scroll 🧻" Margin="0,4"/>
        <CheckBox x:Name="MoodsBox"         Content="Lifelike moods (naps at night) 🌙" Margin="0,4"/>
        <CheckBox x:Name="SystemReactionsBox" Content="React to my computer 💻"  Margin="0,4"/>
        <CheckBox x:Name="AutoUpdateBox"    Content="Auto-update from GitHub 🔄"  Margin="0,4"/>
        <CheckBox x:Name="AutostartBox"     Content="Start with Windows"        Margin="0,4"/>

        <Separator Margin="0,14"/>

        <TextBlock Text="🧘 Stretch reminder" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Remind me every" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="StretchIntervalBox" Width="120" VerticalAlignment="Center">
                <ComboBoxItem Content="Off"        Tag="0"/>
                <ComboBoxItem Content="15 minutes" Tag="15"/>
                <ComboBoxItem Content="30 minutes" Tag="30"/>
                <ComboBoxItem Content="45 minutes" Tag="45"/>
                <ComboBoxItem Content="60 minutes" Tag="60"/>
            </ComboBox>
        </StackPanel>
        <TextBlock Text="Your cat will stretch too  🐱" FontSize="10"
                   Foreground="#FF8855BB" Margin="0,4,0,0"/>

        <Separator Margin="0,14"/>

        <TextBlock Text="🤖 AI companion (beta)" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <CheckBox x:Name="AiEnableBox" Content="Let me chat with the cat" Margin="0,4"/>
        <CheckBox x:Name="AiToolsBox"   Content="Allow cute tools (time, weather, stats)" Margin="0,4"/>
        <CheckBox x:Name="AiChatterBox" Content="Let the cat speak up on its own 💬" Margin="0,4"/>

        <TextBlock Text="Free Gemini API key" Margin="0,8,0,2"/>
        <PasswordBox x:Name="AiKeyBox" Margin="0,0,0,2"/>
        <TextBlock Text="Stored only on this PC — never uploaded or shared. Get a free key at aistudio.google.com."
                   FontSize="10" Foreground="#FF8855BB" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <TextBlock Text="Cat personality" Margin="0,0,0,2"/>
        <TextBox x:Name="AiPersonaBox" TextWrapping="Wrap" AcceptsReturn="True" Height="54"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CloseButton" Content="Done" Width="80" Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
