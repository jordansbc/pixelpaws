<Window x:Class="DesktopPet.UI.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixelPaws"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Grid Background="Transparent">
        <!-- Sprite -->
        <Image x:Name="PetImage"
               RenderOptions.BitmapScalingMode="HighQuality"
               Stretch="Fill"
               SnapsToDevicePixels="True">
            <Image.RenderTransform>
                <ScaleTransform x:Name="FlipTransform" ScaleX="1" ScaleY="1" />
            </Image.RenderTransform>
        </Image>

        <!-- Red heat flush for fast typing — clipped to the cat's silhouette via an
             OpacityMask of the current frame, so only the cat reddens (not the window). -->
        <Rectangle x:Name="RedOverlay"
                   Fill="#FFFF3A1E"
                   Opacity="0"
                   IsHitTestVisible="False">
            <Rectangle.OpacityMask>
                <ImageBrush x:Name="HeatMaskBrush" Stretch="Fill" />
            </Rectangle.OpacityMask>
            <Rectangle.RenderTransform>
                <ScaleTransform x:Name="HeatFlip" ScaleX="1" ScaleY="1" />
            </Rectangle.RenderTransform>
        </Rectangle>
    </Grid>
</Window>
