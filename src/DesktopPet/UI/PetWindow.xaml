<Window x:Class="DesktopPet.UI.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixelPaws"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Grid Background="Transparent">
        <!-- Sprite -->
        <Image x:Name="PetImage"
               RenderOptions.BitmapScalingMode="HighQuality"
               Stretch="Fill"
               SnapsToDevicePixels="True">
            <Image.RenderTransform>
                <ScaleTransform x:Name="FlipTransform" ScaleX="1" ScaleY="1" />
            </Image.RenderTransform>
        </Image>

        <!-- Red heat overlay for fast typing — drawn on top, non-interactive -->
        <Rectangle x:Name="RedOverlay"
                   Fill="#FFE00000"
                   Opacity="0"
                   IsHitTestVisible="False" />
    </Grid>
</Window>
